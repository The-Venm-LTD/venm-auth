# ── Venm Auth Demo Server ──────────────────────────────────────────────
# Copy this file to .env and fill in your credentials before starting.
#
# Usage:
#   1. cp .env.example .env
#   2. Fill in at least one OAuth provider's credentials
#   3. Set JWT_SECRET (min 32 characters)
#   4. Run: node server/index.js
#
# The Vite dev server runs on port 3000 and proxies /api/auth requests
# to this Express server on port 3001.
# ─────────────────────────────────────────────────────────────────────────

# ── OAuth Providers (add at least one) ────────────────────────────────

# Google OAuth 2.0 credentials
# Get these from the Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Make sure the OAuth consent screen is configured for "External" user type
# (not "Internal") so that any Google account can sign in.
# Add http://localhost:3001/api/auth/google/callback to authorized redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth credentials
# Get these from the Facebook Developers Console: https://developers.facebook.com/apps
# Add http://localhost:3001/api/auth/facebook/callback to OAuth redirect URIs
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── JWT Signing Secret ─────────────────────────────────────────────────

# Secret key used to sign and verify JWT tokens.
# Must be at least 32 characters long for HS256 security.
JWT_SECRET=your-secret-at-least-32-characters-long

# ── Database ──────────────────────────────────────────────────────────

# MongoDB connection URI (optional — uses in-memory adapter if not set).
# Data stored in the in-memory adapter is lost on server restart.
MONGODB_URI=
MONGODB_DATABASE=venm-auth-demo

# ── Server ────────────────────────────────────────────────────────────

# Port for the Express auth server (default: 3001)
PORT=3001

# Origin of the client application (for CORS and CSRF protection).
# Set this to the URL of your frontend app.
CLIENT_ORIGIN=http://localhost:3000
