# ═══════════════════════════════════════════════════════════════════════
# Venm Auth Demo — Shared Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#
# This file is used by ALL three apps:
#   - Express server (port 3001) — reads GOOGLE_CLIENT_ID, JWT_SECRET, etc.
#   - Web demo (Vite, port 3000) — reads VITE_* vars
#   - Ionic app (Vite, port 3002) — reads VITE_* vars
#
# Usage:
#   1. Copy this file to .env  →  cp .env.example .env
#   2. Fill in your credentials
#   3. Run from the demo root:  pnpm dev
# ═══════════════════════════════════════════════════════════════════════

# ── OAuth Providers (add at least one) ────────────────────────────────

# Google OAuth 2.0 — Web client (required for the server to exchange codes)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=



# Facebook OAuth credentials
# Get these from: https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Client-side VITE_* vars (prefix required by Vite) ─────────────────
# These are picked up by the Web Demo (Vite :3000) and Ionic App (Vite :3002)
VITE_GOOGLE_CLIENT_ID=

VITE_FACEBOOK_APP_ID=

# ── JWT Signing Secret ─────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens.
# Must be at least 32 characters long for HS256 security.
JWT_SECRET=your-secret-at-least-32-characters-long

# ── Database ──────────────────────────────────────────────────────────
# MongoDB connection URI (optional — uses in-memory adapter if not set).
# Data stored in the in-memory adapter is lost on server restart.
MONGODB_URI=
MONGODB_DATABASE=venm-auth-demo

# ── Server ────────────────────────────────────────────────────────────
# Port for the Express auth server (default: 3001)
PORT=3001

# API URL for the Ionic App (use 10.0.2.2 for Android emulator or your local IP for physical devices)
VITE_API_URL=http://localhost:3001/api/auth

# Allowed client origins for CORS and CSRF protection (comma-separated)
CLIENT_ORIGIN=http://localhost:3000,http://localhost:3002,http://localhost,https://localhost
